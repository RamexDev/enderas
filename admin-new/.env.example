# Backend API base URL (same value used by the existing admin app)
VITE_API_BASE_URL=http://localhost:5000/api/v1

# Upload root, used to resolve stored image paths into browser-loadable URLs.
# Should match the backend's UPLOAD_PATH public URL.
VITE_UPLOAD_BASE_URL=http://localhost:5000/uploads

# Public-facing website URL. Used by the "View live site" link in the preview toolbar.
# Optional — when unset, the editor falls back to the API origin.
VITE_FRONTEND_URL=http://localhost:5173

# Editor app name shown in the sidebar header.
VITE_APP_NAME=Enderas Visual Editor
