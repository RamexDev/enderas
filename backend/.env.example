PORT=5000
NODE_ENV=development

DB_HOST=localhost
DB_PORT=3306
DB_NAME=enderas
DB_USER=root
DB_PASSWORD=

JWT_SECRET=change-this-in-production-min-32-chars-long
JWT_REFRESH_SECRET=change-this-in-production-too-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Log level: debug, info, warn, error (defaults to debug in dev, info in production)
LOG_LEVEL=debug

# Production: set real origins (must not be localhost). Required when NODE_ENV=production.
# ADMIN_URL    → /api/v1/auth/* and admin management routes
# FRONTEND_URL → /api/v1/public/*
ADMIN_URL=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_URL=http://localhost:5174,http://127.0.0.1:5174
API_BASE_URL=http://localhost:5000/api/v1

UPLOAD_PATH=./src/uploads
MAX_FILE_SIZE=5242880

SUPER_ADMIN_EMAIL=admin@enderas.com
SUPER_ADMIN_PASSWORD=

# Notifications (optional — leave blank to skip)
# Email (SMTP) — contact form submissions are emailed here
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ADMIN_EMAIL=
# Webhook — POST JSON payload on new contact message
NOTIFICATION_WEBHOOK_URL=
