PORT=5000
NODE_ENV=development

DB_HOST=localhost
DB_PORT=3306
DB_NAME=enderas
DB_USER=root
DB_PASSWORD=

JWT_SECRET=change-this-in-production-min-32-chars-long
JWT_REFRESH_SECRET=change-this-in-production-too-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Log level: debug, info, warn, error (defaults to debug in dev, info in production)
LOG_LEVEL=debug

# Required in all environments. Set real origins in production (must not be localhost).
# ADMIN_URL    → /api/v1/auth/* and admin management routes (ports 5175 or 5176 in dev)
# FRONTEND_URL → /api/v1/public/* (port 5173 in dev)
ADMIN_URL=http://localhost:5175,http://localhost:5176,http://127.0.0.1:5175,http://127.0.0.1:5176
FRONTEND_URL=http://localhost:5173,http://127.0.0.1:5173
API_BASE_URL=http://localhost:5000/api/v1

UPLOAD_PATH=./src/uploads
MAX_FILE_SIZE=5242880

SUPER_ADMIN_EMAIL=admin@enderas.com
SUPER_ADMIN_PASSWORD=

# ═══════════════════════════════════════════════════════════════
# NOTIFICATIONS
# ═══════════════════════════════════════════════════════════════
# When a user submits the contact form, the admin receives an email
# notification with the message details. This is entirely optional —
# leave all SMTP_* vars blank to skip email entirely (contact form
# submissions still work and are saved in the database).

# ── Email (SMTP) ───────────────────────────────────────────────
# SMTP hostname. Examples:
#   smtp.gmail.com        — Google Gmail
#   smtp.sendgrid.net     — SendGrid (use "apikey" as SMTP_USER)
#   smtp.mailgun.org      — Mailgun
# Leave blank to disable email notifications.
SMTP_HOST=

# SMTP port:
#   587  — STARTTLS (most common, recommended)
#   465  — SSL/TLS (less common)
#   25   — unencrypted (often blocked by ISPs, not recommended)
SMTP_PORT=587

# SMTP authentication username.
#   Gmail:    your full Gmail address (e.g. you@gmail.com)
#   SendGrid: the literal string "apikey"
#   Mailgun:  your SMTP login (e.g. postmaster@yourdomain.com)
SMTP_USER=

# SMTP authentication password.
#   Gmail:    a 16-character App Password (requires 2FA enabled).
#             Generate one at: https://myaccount.google.com/apppasswords
#             → Select app: "Mail" → Select device: "Other" → name it
#   SendGrid: your SendGrid API key
#   Mailgun:  your Mailgun SMTP password
# ──── WARNING: Never commit real credentials to Git ─────────────
SMTP_PASS=

# "From" address shown in the recipient's email client.
# If left blank, SMTP_USER is used instead.
SMTP_FROM=

# The email address that receives contact form notifications.
# Set this to the site admin's email (e.g. admin@yourdomain.com).
# If blank, no email is sent regardless of the SMTP config above.
ADMIN_EMAIL=

# ── Webhook (optional) ─────────────────────────────────────────
# If set, a POST request with a JSON payload is sent to this URL
# every time a new contact message is submitted. The payload shape:
#   { event: "contact_message.created", data: { id, name, email,
#     phone, subject, message, created_at } }
# Leave blank to disable.
NOTIFICATION_WEBHOOK_URL=
